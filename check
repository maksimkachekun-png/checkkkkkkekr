async def validate_token(token: str, device_id: str, device_info: dict = None) -> dict:
    conn = MaxConnection()
    try:
        if not conn.connect():
            return {"valid": False, "error": "Connection failed"}
        
        now_ms = int(time.time() * 1000)
        user_agent = {
            "deviceType": device_info.get("deviceType", "ANDROID") if device_info else "ANDROID",
            "appVersion": device_info.get("appVersion", "26.17.1") if device_info else "26.17.1",
            "osVersion": device_info.get("osVersion", "Android 10") if device_info else "Android 10",
            "timezone": device_info.get("timezone", "Europe/Moscow") if device_info else "Europe/Moscow",
            "screen": device_info.get("screen", "408dpi 1080x2292") if device_info else "408dpi 1080x2292",
            "pushDeviceType": "GCM",
            "arch": device_info.get("arch", "arm64-v8a") if device_info else "arm64-v8a",
            "locale": device_info.get("deviceLocale", device_info.get("locale", "ru")) if device_info else "ru",
            "buildNumber": device_info.get("buildNumber", 6712) if device_info else 6712,
            "deviceName": device_info.get("deviceName", "Android") if device_info else "Android",
            "deviceLocale": device_info.get("deviceLocale", device_info.get("locale", "ru")) if device_info else "ru"
        }
        
        payload = {
            "clientSessionId": now_ms & 0x7FFFFFFF,
            "mt_instanceid": str(uuid.uuid4()),
            "userAgent": user_agent,
            "deviceId": device_id
        }
        conn.send(Packet(Opcode.SESSION_INIT, pack(payload)))
        await asyncio.sleep(0.5)
        
        login_payload = {"token": token, "deviceId": device_id, "userAgent": user_agent}
        resp = conn.send(Packet(Opcode.LOGIN, pack(login_payload)))
        
        if not resp or not resp.payload:
            return {"valid": False, "error": "Empty response"}
        
        data = unpack(resp.payload)
        logger.info(f"Response: {str(data)[:500]}")
        
        phone = deep_find_phone(data)
        
        is_valid = True
        has_2fa = False
        error = None
        
        if isinstance(data, (int, float)):
            return {"valid": True, "phone": phone}
        
        if isinstance(data, list) and len(data) > 0:
            first = data[0]
            if isinstance(first, dict):
                if first.get("passwordChallenge"):
                    has_2fa = True
                elif "error" in first:
                    error_msg = str(first["error"])
                    if "password" in error_msg.lower() or "2fa" in error_msg.lower():
                        has_2fa = True
                    else:
                        is_valid = False
                        error = error_msg
        elif isinstance(data, dict):
            if data.get("passwordChallenge"):
                has_2fa = True
            elif "error" in data:
                error_msg = str(data["error"])
                if "password" in error_msg.lower() or "2fa" in error_msg.lower():
                    has_2fa = True
                else:
                    is_valid = False
                    error = error_msg
        
        if is_valid and has_2fa:
            return {"valid": True, "has_2fa": True, "phone": phone}
        elif is_valid:
            return {"valid": True, "phone": phone}
        else:
            return {"valid": False, "error": error or "Unknown error"}
    except Exception as e:
        return {"valid": False, "error": str(e)}
    finally:
        conn.close()

