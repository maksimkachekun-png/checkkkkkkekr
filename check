async def export_tokens(callback, accs: dict, prefix: str):
    """Экспортирует токены в ZIP и удаляет из базы"""
    msg = await callback.message.answer("⏳ Создаю архив...")
    
    try:
        zip_buffer = BytesIO()
        
        with zipfile.ZipFile(zip_buffer, 'w', zipfile.ZIP_DEFLATED) as zf:
            for acc_id, acc in accs.items():
                token = acc.get("token", "")
                phone = acc.get("phone", "")
                password = acc.get("password", "")
                status = acc.get("status", "")
                device_info = acc.get("device_info", {})
                custom_payload = acc.get("custom_payload", "")
                
                # Имя файла
                if phone:
                    filename = f"{phone}"
                else:
                    filename = f"{acc_id[:8]}"
                
                if password:
                    filename += f"_pass_{password}"
                
                if status == "2fa":
                    filename += "_2FA"
                
                # Содержимое файла
                content = token
                
                if device_info:
                    content += "\n" + json.dumps(device_info, ensure_ascii=False)
                
                if password:
                    content += "\n" + password
                
                if custom_payload:
                    content += f"\nconst customPayload = \"{custom_payload}\";"
                
                zf.writestr(f"{filename}.txt", content)
        
        zip_buffer.seek(0)
        
        # Временный файл
        temp_file = f"export_{prefix}_{int(time.time())}.zip"
        with open(temp_file, 'wb') as f:
            f.write(zip_buffer.read())
        
        # Отправляем
        await callback.message.answer_document(
            FSInputFile(temp_file),
            caption=f"💾 {prefix}\n📦 Токенов: {len(accs)}\n🗑 Удалены из базы"
        )
        
        os.remove(temp_file)
        
        # Удаляем из базы
        for acc_id in accs:
            if acc_id in accounts:
                del accounts[acc_id]
        save_data()
        
        await msg.edit_text(
            f"✅ Выгружено <b>{len(accs)}</b> токенов\n"
            f"🗑 Удалены из базы\n"
            f"📊 Осталось: <b>{len(accounts)}</b>",
            parse_mode="HTML"
        )
        
    except Exception as e:
        logger.error(f"Export error: {e}")
        await msg.edit_text(f"❌ Ошибка: {str(e)[:200]}")
    
    await callback.answer()

