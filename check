def deep_find_phone(data, depth=0):
    if depth > 10:
        return ""
    if isinstance(data, dict):
        if "user" in data:
            user = data["user"]
            if isinstance(user, dict):
                phone = user.get("phone", "")
                if phone and isinstance(phone, (str, int)) and len(str(phone)) >= 10:
                    return str(phone)
        for key in ["phone", "phoneNumber", "login"]:
            val = data.get(key, "")
            if isinstance(val, (str, int)) and len(str(val)) >= 10 and any(c.isdigit() for c in str(val)):
                return str(val)
        for key, value in data.items():
            if isinstance(value, (str, int)) and len(str(value)) >= 10:
                cleaned = re.sub(r'[\s\(\)\-]', '', str(value))
                if cleaned.isdigit() and len(cleaned) >= 10:
                    return cleaned
            elif isinstance(value, (dict, list)):
                result = deep_find_phone(value, depth + 1)
                if result:
                    return result
    elif isinstance(data, list):
        for item in data:
            result = deep_find_phone(item, depth + 1)
            if result:
                return result
    return ""

