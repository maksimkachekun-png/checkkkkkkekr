class TokenParser:
    @staticmethod
    def extract_token(text: str) -> str:
        match = re.search(r'"token"\s*:\s*"([^"]+)"', text)
        if match:
            return match.group(1)
        match = re.search(r'(An_[A-Za-z0-9\-_=+]{100,})', text)
        if match:
            return match.group(1)
        match = re.search(r'(?:^|\s)([A-Za-z0-9\-_=+]{100,})(?:\s|$)', text)
        if match:
            token = match.group(1)
            if not token.startswith('{') and not token.startswith('const'):
                return token
        return None
    
    @staticmethod
    def extract_device_info(text: str) -> dict:
        device_info = {}
        json_match = re.search(r'\{[^{}]*"deviceType"[^{}]*\}', text)
        if json_match:
            try:
                data = json.loads(json_match.group(0))
                if "userAgent" in data:
                    device_info.update(data["userAgent"])
                else:
                    device_info.update(data)
            except:
                pass
        if not device_info:
            fields = {
                "deviceId": r'"deviceId"\s*:\s*"([^"]+)"',
                "deviceType": r'"deviceType"\s*:\s*"([^"]+)"',
                "appVersion": r'"appVersion"\s*:\s*"([^"]+)"',
                "osVersion": r'"osVersion"\s*:\s*"([^"]+)"',
                "deviceName": r'"deviceName"\s*:\s*"([^"]+)"',
                "deviceLocale": r'"deviceLocale"\s*:\s*"([^"]+)"',
                "buildNumber": r'"buildNumber"\s*:\s*(\d+)',
                "screen": r'"screen"\s*:\s*"([^"]+)"',
                "timezone": r'"timezone"\s*:\s*"([^"]+)"',
            }
            for field, pattern in fields.items():
                match = re.search(pattern, text)
                if match:
                    if field == "buildNumber":
                        device_info[field] = int(match.group(1))
                    else:
                        device_info[field] = match.group(1)
        return device_info
    
    @staticmethod
    def extract_custom_payload(text: str) -> str:
        match = re.search(r'customPayload\s*=\s*"(\d+)"', text)
        if match:
            return match.group(1)
        match = re.search(r'"customPayload"\s*:\s*"(\d+)"', text)
        if match:
            return match.group(1)
        match = re.search(r'"customPayload"\s*:\s*(\d+)', text)
        if match:
            return match.group(1)
        return None
    
    @staticmethod
    def extract_password(text: str) -> str:
        """Ищет пароль в тексте"""
        # После JSON перед const customPayload
        match = re.search(r'\}\s*([A-Za-z0-9@#$%^&*!]+)\s*(?:const\s+customPayload|$)', text)
        if match:
            pwd = match.group(1)
            if 6 <= len(pwd) <= 50:
                return pwd
        
        # На следующей строке после }
        match = re.search(r'\}\n\s*([A-Za-z0-9@#$%^&*!]+)', text)
        if match:
            pwd = match.group(1)
            if 6 <= len(pwd) <= 50:
                return pwd
        
        # Строка со спецсимволами
        lines = text.strip().split('\n')
        for line in lines:
            line = line.strip()
            if len(line) < 6 or len(line) > 50:
                continue
            if line.startswith('{') or line.startswith('const') or line.startswith('An_'):
                continue
            if re.search(r'[!@#$%^&*]', line):
                return line
        
        # Строка после JSON (буквы + цифры/спецсимволы)
        for i, line in enumerate(lines):
            line = line.strip()
            if not line:
                continue
            if i > 0 and lines[i-1].strip().endswith('}'):
                if 6 <= len(line) <= 50:
                    if not line.startswith('const') and not line.startswith('An_') and not line.startswith('{'):
                        has_letter = bool(re.search(r'[A-Za-z]', line))
                        has_digit_or_special = bool(re.search(r'[0-9!@#$%^&*]', line))
                        if has_letter and has_digit_or_special:
                            return line
        
        return ""
    
    @staticmethod
    def parse_content(content: str) -> list:
        results = []
        
        # Пробуем JSON
        try:
            data = json.loads(content)
            if isinstance(data, list):
                for item in data:
                    if isinstance(item, dict) and "token" in item:
                        token = item["token"]
                        if len(token) > 50:
                            results.append({
                                "token": token,
                                "device_info": item.get("device_profile") or item.get("deviceInfo") or {},
                                "password": item.get("password") or "",
                                "phone": item.get("phone") or "",
                                "custom_payload": str(item.get("customPayload", "")) if item.get("customPayload") else None
                            })
                if results:
                    return results
            if isinstance(data, dict):
                if "token" in data:
                    token = data["token"]
                    if len(token) > 50:
                        results.append({
                            "token": token,
                            "device_info": data.get("device_profile") or data.get("deviceInfo") or {},
                            "password": data.get("password") or "",
                            "phone": data.get("phone") or "",
                            "custom_payload": str(data.get("customPayload", "")) if data.get("customPayload") else None
                        })
                        return results
        except:
            pass
        
        # Построчный JSON
        lines = content.strip().split('\n')
        for line in lines:
            line = line.strip()
            if not line:
                continue
            try:
                data = json.loads(line)
                if isinstance(data, dict) and "token" in data:
                    token = data["token"]
                    if len(token) > 50:
                        results.append({
                            "token": token,
                            "device_info": data.get("device_profile") or data.get("deviceInfo") or {},
                            "password": data.get("password") or "",
                            "phone": data.get("phone") or "",
                            "custom_payload": str(data.get("customPayload", "")) if data.get("customPayload") else None
                        })
            except:
                pass
        
        if results:
            return results
        
        # Текстовые блоки
        blocks = re.split(r'\n\s*\n', content)
        for block in blocks:
            block = block.strip()
            if not block:
                continue
            
            token = TokenParser.extract_token(block)
            if not token:
                continue
            
            password = TokenParser.extract_password(block)
            device_info = TokenParser.extract_device_info(block)
            custom_payload = TokenParser.extract_custom_payload(block)
            
            if "deviceId" not in device_info:
                device_info["deviceId"] = str(uuid.uuid4())
            
            results.append({
                "token": token,
                "device_info": device_info,
                "password": password,
                "phone": "",
                "custom_payload": custom_payload
            })
        
        return results

