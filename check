class Packet:
    VERSION = 10
    HEADER_SIZE = 10

    def __init__(self, opcode: int, payload: bytes = b"", sequence: int = 0, cmd: int = 0):
        self.version = self.VERSION
        self.cmd = cmd
        self.sequence = sequence
        self.opcode = opcode
        self.payload = payload

    def to_bytes(self) -> bytes:
        payload_bytes = self.payload
        body_len = len(payload_bytes)
        flags_and_len = (body_len & 0x00FFFFFF)
        header = struct.pack(">B B H H I", self.version, self.cmd, 
                           self.sequence & 0xFFFF, self.opcode & 0xFFFF, flags_and_len)
        return header + payload_bytes

    @classmethod
    def from_bytes(cls, data: bytes):
        if len(data) < cls.HEADER_SIZE:
            raise ValueError("Too short")
        header = data[:cls.HEADER_SIZE]
        version, cmd, sequence, opcode, flags_and_len = struct.unpack(">B B H H I", header)
        body_len = flags_and_len & 0x00FFFFFF
        payload = data[cls.HEADER_SIZE:cls.HEADER_SIZE + body_len]
        return cls(opcode=opcode, payload=payload, sequence=sequence, cmd=cmd)

class Opcode:
    SESSION_INIT = 6
    LOGIN = 19

def pack(data: dict) -> bytes:
    return msgpack.packb(data, use_bin_type=True)

def unpack(data: bytes) -> dict:
    try:
        return msgpack.unpackb(data, raw=False, strict_map_key=False)
    except:
        try:
            unpacker = msgpack.Unpacker(raw=False, strict_map_key=False)
            unpacker.feed(data)
            return next(unpacker)
        except:
            return {}

class MaxConnection:
    HOST = "api.oneme.ru"
    PORT = 443

    def __init__(self):
        self._sock = None
        self._sequence = 0
        self._lock = threading.Lock()
        self._pending = {}
        self._responses = {}
        self._running = False
        self._buffer = bytearray()

    def connect(self) -> bool:
        try:
            plain = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            plain.settimeout(10)
            plain.connect((self.HOST, self.PORT))
            ctx = ssl.create_default_context()
            ctx.check_hostname = False
            ctx.verify_mode = ssl.CERT_NONE
            self._sock = ctx.wrap_socket(plain, server_hostname=self.HOST)
            self._sock.settimeout(5)
            self._running = True
            self._buffer = bytearray()
            self._pending.clear()
            self._responses.clear()
            threading.Thread(target=self._reader, daemon=True).start()
            return True
        except:
            return False

    def close(self):
        self._running = False
        if self._sock:
            try: self._sock.close()
            except: pass
            self._sock = None

    def _reader(self):
        while self._running and self._sock:
            try:
                chunk = self._sock.recv(8192)
                if not chunk: break
                self._buffer.extend(chunk)
                self._parse()
            except socket.timeout: continue
            except: break

    def _parse(self):
        while len(self._buffer) >= Packet.HEADER_SIZE:
            header = bytes(self._buffer[:Packet.HEADER_SIZE])
            _, _, seq, opcode, flags_and_len = struct.unpack(">B B H H I", header)
            body_len = flags_and_len & 0x00FFFFFF
            total = Packet.HEADER_SIZE + body_len
            if len(self._buffer) < total: break
            data = bytes(self._buffer[:total])
            self._buffer = self._buffer[total:]
            try:
                packet = Packet.from_bytes(data)
                if packet.sequence in self._pending:
                    self._responses[packet.sequence] = packet
                    self._pending[packet.sequence].set()
            except: continue

    def send(self, packet: Packet, wait=True):
        with self._lock:
            self._sequence = (self._sequence + 1) & 0xFFFF
            packet.sequence = self._sequence
            seq = packet.sequence
            if wait:
                event = threading.Event()
                self._pending[seq] = event
                self._responses.pop(seq, None)
        self._sock.sendall(packet.to_bytes())
        if not wait: return None
        if not self._pending[seq].wait(60):
            self._pending.pop(seq, None)
            raise TimeoutError(f"Timeout seq {seq}")
        self._pending.pop(seq, None)
        return self._responses.pop(seq, None)

# ==================== ПАРСЕР ТОКЕНОВ ====================

class TokenParser:
    @staticmethod
    def extract_token(text: str) -> str:
        match = re.search(r'(An_[A-Za-z0-9\-_=+]{100,})', text)
        if match:
            return match.group(1)
        
        match = re.search(r'(?:^|\s)([A-Za-z0-9\-_=+]{100,})(?:\s|$)', text)
        if match:
            token = match.group(1)
            if not token.startswith('{') and not token.startswith('const'):
                return token
        return None
    
    @staticmethod
    def extract_password(text: str) -> str:
        # Ищем пароль после JSON }
        match = re.search(r'\}\s+([A-Za-z0-9@#$%^&*!]+)\s*(?:const\s+customPayload|$)', text)
        if match:
            return match.group(1)
        
        # Ищем в JSON
        for pattern in [r'"password"\s*:\s*"([^"]+)"', r'"pass"\s*:\s*"([^"]+)"']:
            match = re.search(pattern, text)
            if match:
                return match.group(1)
        
        # Ищем строку со спецсимволами (пароль)
        lines = text.strip().split('\n')
        for line in lines:
            line = line.strip()
            if len(line) < 4 or len(line) > 50:
                continue
            if line.startswith('{') or line.startswith('const') or line.startswith('An_'):
                continue
            if re.search(r'[!@#$%^&*]', line):
                return line
        
        return ""
    
    @staticmethod
    def extract_device_info(text: str) -> dict:
        device_info = {}
        
        json_match = re.search(r'\{[^{}]*"deviceType"[^{}]*\}', text)
        if json_match:
            try:
                data = json.loads(json_match.group(0))
                if "userAgent" in data:
                    device_info.update(data["userAgent"])
                else:
                    device_info.update(data)
            except:
                pass
        
        if not device_info:
            fields = {
                "deviceId": r'"deviceId"\s*:\s*"([^"]+)"',
                "deviceType": r'"deviceType"\s*:\s*"([^"]+)"',
                "appVersion": r'"appVersion"\s*:\s*"([^"]+)"',
                "osVersion": r'"osVersion"\s*:\s*"([^"]+)"',
                "deviceName": r'"deviceName"\s*:\s*"([^"]+)"',
                "deviceLocale": r'"deviceLocale"\s*:\s*"([^"]+)"',
                "buildNumber": r'"buildNumber"\s*:\s*(\d+)',
                "screen": r'"screen"\s*:\s*"([^"]+)"',
                "timezone": r'"timezone"\s*:\s*"([^"]+)"',
            }
            
            for field, pattern in fields.items():
                match = re.search(pattern, text)
                if match:
                    if field == "buildNumber":
                        device_info[field] = int(match.group(1))
                    else:
                        device_info[field] = match.group(1)
        
        return device_info
    
    @staticmethod
    def extract_custom_payload(text: str) -> str:
        match = re.search(r'customPayload\s*=\s*"(\d+)"', text)
        if match:
            return match.group(1)
        match = re.search(r'"customPayload"\s*:\s*"(\d+)"', text)
        if match:
            return match.group(1)
        return None
    
    @staticmethod
    def parse_content(content: str) -> list:
        results = []
        
        # Пробуем JSON
        try:
            data = json.loads(content)
            if isinstance(data, list):
                for item in data:
                    if isinstance(item, dict):
                        token = item.get("token") or item.get("accessToken") or ""
                        if token and len(token) > 50:
                            results.append({
                                "token": token,
                                "device_info": item.get("deviceInfo") or item.get("userAgent") or {},
                                "password": item.get("password") or "",
                                "custom_payload": str(item.get("customPayload", "")) if item.get("customPayload") else None
                            })
            elif isinstance(data, dict):
                token = data.get("token") or data.get("accessToken") or ""
                if token and len(token) > 50:
                    results.append({
                        "token": token,
                        "device_info": data.get("deviceInfo") or data.get("userAgent") or {},
                        "password": data.get("password") or "",
                        "custom_payload": str(data.get("customPayload", "")) if data.get("customPayload") else None
                    })
            if results:
                return results
        except:
            pass
        
        # Парсим как текст
        blocks = re.split(r'\n\s*\n', content)
        
        for block in blocks:
            block = block.strip()
            if not block:
                continue
            
            token = TokenParser.extract_token(block)
            if not token:
                continue
            
            password = TokenParser.extract_password(block)
            device_info = TokenParser.extract_device_info(block)
            custom_payload = TokenParser.extract_custom_payload(block)
            
            if "deviceId" not in device_info:
                device_info["deviceId"] = str(uuid.uuid4())
            
            results.append({
                "token": token,
                "device_info": device_info,
                "password": password,
                "custom_payload": custom_payload
            })
        
        return results

