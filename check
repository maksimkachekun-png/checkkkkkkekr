async def validate_token(token: str, device_id: str, device_info: dict = None) -> dict:
    conn = MaxConnection()
    
    try:
        if not conn.connect():
            return {"valid": False, "error": "Connection failed"}
        
        now_ms = int(time.time() * 1000)
        user_agent = {
            "deviceType": "ANDROID",
            "appVersion": "26.17.1",
            "osVersion": "Android 10",
            "timezone": "Europe/Moscow",
            "screen": "408dpi 1080x2292",
            "pushDeviceType": "GCM",
            "arch": "arm64-v8a",
            "locale": "ru",
            "buildNumber": 6712,
            "deviceName": "Google Pixel 7",
            "deviceLocale": "ru"
        }
        
        if device_info:
            user_agent.update(device_info)
        
        payload = {
            "clientSessionId": now_ms & 0x7FFFFFFF,
            "mt_instanceid": str(uuid.uuid4()),
            "userAgent": user_agent,
            "deviceId": device_id
        }
        
        conn.send(Packet(Opcode.SESSION_INIT, pack(payload)))
        await asyncio.sleep(0.5)
        
        login_payload = {
            "token": token,
            "deviceId": device_id,
            "userAgent": user_agent
        }
        
        resp = conn.send(Packet(Opcode.LOGIN, pack(login_payload)))
        
        if not resp or not resp.payload:
            return {"valid": False, "error": "Empty response"}
        
        data = unpack(resp.payload)
        
        phone = ""
        
        if isinstance(data, (int, float)):
            return {"valid": True, "user_id": int(data)}
        
        if isinstance(data, list) and len(data) > 0:
            first = data[0]
            if isinstance(first, dict):
                if "user" in first:
                    user_data = first["user"]
                    if isinstance(user_data, dict):
                        phone = user_data.get("phone", "")
                
                if first.get("passwordChallenge"):
                    return {"valid": True, "has_2fa": True, "phone": phone}
                if "error" in first:
                    error_msg = str(first["error"])
                    if "password" in error_msg.lower():
                        return {"valid": True, "has_2fa": True, "phone": phone}
                    return {"valid": False, "error": error_msg}
            elif isinstance(first, (int, float)):
                return {"valid": True, "user_id": int(first)}
            return {"valid": True, "phone": phone}
        
        if isinstance(data, dict):
            if "user" in data:
                user_data = data["user"]
                if isinstance(user_data, dict):
                    phone = user_data.get("phone", "")
            
            if data.get("passwordChallenge"):
                return {"valid": True, "has_2fa": True, "phone": phone}
            if "error" in data:
                error_msg = str(data["error"])
                if "password" in error_msg.lower():
                    return {"valid": True, "has_2fa": True, "phone": phone}
                return {"valid": False, "error": error_msg}
            return {"valid": True, "phone": phone}
        
        return {"valid": True, "phone": phone}
        
    except Exception as e:
        return {"valid": False, "error": str(e)}
    finally:
        conn.close()

