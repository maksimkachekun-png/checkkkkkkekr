@dp.message(AuthState.waiting_for_file, F.document)
async def handle_file(message: types.Message, state: FSMContext):
    if message.from_user.id != ADMIN_ID:
        return
    
    doc = message.document
    file_name = doc.file_name.lower()
    
    if not file_name.endswith(('.txt', '.json', '.zip')):
        await message.answer("❌ Отправьте файл .txt, .json или .zip")
        return
    
    msg = await message.answer("⏳ Обрабатываю файл...")
    await state.clear()
    
    try:
        file = await bot.get_file(doc.file_id)
        file_bytes = await bot.download_file(file.file_path)
        raw_bytes = file_bytes.read()
        
        all_tokens = []
        
        if file_name.endswith('.zip'):
            try:
                zip_buffer = BytesIO(raw_bytes)
                with zipfile.ZipFile(zip_buffer, 'r') as zf:
                    for inner_file in zf.namelist():
                        if not inner_file.endswith(('.txt', '.json')):
                            continue
                        try:
                            content_bytes = zf.read(inner_file)
                            for encoding in ['utf-8', 'cp1251', 'latin-1']:
                                try:
                                    content = content_bytes.decode(encoding)
                                    break
                                except:
                                    continue
                            else:
                                continue
                            
                            tokens = TokenParser.parse_content(content)
                            all_tokens.extend(tokens)
                        except:
                            continue
            except zipfile.BadZipFile:
                await msg.edit_text("❌ Файл повреждён")
                return
        else:
            for encoding in ['utf-8', 'cp1251', 'latin-1']:
                try:
                    content = raw_bytes.decode(encoding)
                    break
                except:
                    continue
            else:
                await msg.edit_text("❌ Не удалось прочитать файл")
                return
            
            all_tokens = TokenParser.parse_content(content)
        
        if not all_tokens:
            await msg.edit_text("❌ Токены не найдены в файле")
            return
        
        await msg.edit_text(f"🔍 Проверяю <b>{len(all_tokens)}</b> токенов...", parse_mode="HTML")
        
        valid_count = 0
        invalid_count = 0
        twofa_count = 0
        duplicate_count = 0
        results = []
        
        total = len(all_tokens)
        checked = 0
        
        for token_data in all_tokens:
            checked += 1
            token = token_data["token"]
            password = token_data.get("password", "")
            device_info = token_data.get("device_info", {})
            custom_payload = token_data.get("custom_payload")
            
            if is_duplicate_token(token):
                duplicate_count += 1
                results.append("· ↻ дубликат")
                continue
            
            device_id = device_info.get("deviceId", str(uuid.uuid4()))
            result = await validate_token(token, device_id, device_info)
            
            phone = result.get("phone", "")
            if phone:
                phone = re.sub(r'[\s\(\)\-]', '', phone)
                if phone.isdigit() and len(phone) == 10:
                    phone = '7' + phone
            
            if result["valid"]:
                if result.get("has_2fa"):
                    twofa_count += 1
                    status = "2fa"
                    results.append(f"· {phone or '?'} 🔐 2FA | пароль: {password}" if password else f"· {phone or '?'} 🔐 2FA")
                else:
                    valid_count += 1
                    status = "valid"
                    results.append(f"· {phone or '?'} ✓ | пароль: {password}" if password else f"· {phone or '?'} ✓")
                
                # Сохраняем в базу ТОЛЬКО рабочие
                acc_id = str(uuid.uuid4())[:8]
                accounts[acc_id] = {
                    "token": token,
                    "device_id": device_id,
                    "phone": phone or "",
                    "password": password,
                    "device_info": device_info,
                    "custom_payload": custom_payload,
                    "status": status,
                    "checked_at": time.time()
                }
            else:
                invalid_count += 1
                error = result.get("error", "неизвестно")
                results.append(f"· {phone or '?'} ✗ {error[:80]}")
            
            if checked % 10 == 0 or checked == total:
                try:
                    await msg.edit_text(
                        f"🔍 Проверка: <b>{checked}/{total}</b>\n"
                        f"✅ Рабочих: <b>{valid_count}</b>\n"
                        f"🔐 2FA: <b>{twofa_count}</b>\n"
                        f"❌ Битых: <b>{invalid_count}</b>\n"
                        f"🔄 Дублей: <b>{duplicate_count}</b>",
                        parse_mode="HTML"
                    )
                except:
                    pass
        
        save_data()
        
        report = f"👍 <b>Проверка завершена!</b>\n\n"
        report += f"📦 Проверено: <b>{total}</b>\n"
        report += f"✅ Рабочих: <b>{valid_count}</b>\n"
        report += f"🔐 2FA: <b>{twofa_count}</b>\n"
        report += f"❌ Битых: <b>{invalid_count}</b>\n"
        report += f"🔄 Дублей: <b>{duplicate_count}</b>\n"
        report += f"📊 В базе: <b>{len(accounts)}</b>\n\n"
        report += "\n".join(results[:30])
        
        if len(results) > 30:
            report += f"\n\n...и ещё {len(results) - 30}"
        
        if len(report) > 4000:
            parts = []
            current = ""
            for line in report.split('\n'):
                if len(current) + len(line) + 1 > 4000:
                    parts.append(current)
                    current = line + '\n'
                else:
                    current += line + '\n'
            if current:
                parts.append(current)
            
            await msg.edit_text(parts[0], parse_mode="HTML")
            for part in parts[1:]:
                await message.answer(part, parse_mode="HTML")
        else:
            await msg.edit_text(report, parse_mode="HTML")
        
    except Exception as e:
        logger.error(f"Error: {e}")
        await msg.edit_text(f"❌ Ошибка: {str(e)[:500]}")

